# Copy sang .env để chạy local. .env và .env.* đều bị gitignore — đừng commit.
#
# LƯU Ý: Vite nhúng mọi biến VITE_* thẳng vào bundle JS gửi xuống trình duyệt.
# Không đặt secret thật ở đây; coi mọi giá trị VITE_* là công khai.

# Base URL của API khi chạy dev.
# - Trỏ thẳng lên server thật: https://api.vietride.online
#   (gateway bật CORS `origin: true` nên gọi từ localhost được)
# - Hoặc chạy BE local bằng infra/docker/docker-compose.yml: http://localhost:3000
#
# Trên PRODUCTION biến này để RỖNG: FE và API cùng origin (nginx route /v1/ sang
# gateway) nên client gọi bằng path tương đối, không dính CORS. Dockerfile tự ghi
# giá trị rỗng vào .env.production.local lúc build — không cần khai ở đây.
VITE_API_BASE_URL=https://api.vietride.online

# Builder.io — lấy key riêng của bạn tại https://builder.io/account/space
VITE_PUBLIC_BUILDER_KEY=

# Tuỳ chọn: OSRM routing cho trang Manager/Routes.
# Bỏ trống sẽ dùng mặc định https://router.project-osrm.org
VITE_ROUTING_API_URL=
